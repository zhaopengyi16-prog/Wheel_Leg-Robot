# Explicitly keep firmware source and project files trackable
!firmware/**/Core/**
!firmware/**/Drivers/**
!firmware/**/*.ioc
!firmware/**/*.uvprojx
!firmware/**/*.uvoptx

# Re-apply exclusions after broad firmware keep rules
